# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=VacationManagement
DB_USER=postgres
DB_PASSWORD=change-me

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=change-this-secret

# Existing SMTP keys (supported)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-sending-email@yourdomain.com
SMTP_PASS=your-email-password
EMAIL_FROM=Leave Management System <noreply@yourdomain.com>
EMAIL_ORGANIZER=noreply@yourdomain.com
EMAIL_FROM_NAME=Leave Management System

# New aliases (also supported)
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=your-sending-email@yourdomain.com
EMAIL_PASSWORD=your-email-password

# Cron
AUTO_APPROVE_CRON_ENABLED=true